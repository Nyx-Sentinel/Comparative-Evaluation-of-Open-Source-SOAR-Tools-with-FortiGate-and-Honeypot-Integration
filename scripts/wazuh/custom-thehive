#!/usr/bin/env python3
# ============================================================
# WZ-PB2/3/4: Wazuh → TheHive Integration Script
# ============================================================
# Location: /var/ossec/integrations/custom-thehive
# Triggered by: Wazuh integratord daemon
# Actions:
#   WZ-PB2: AbuseIPDB enrichment
#   WZ-PB3: TheHive alert creation
#   WZ-PB4: TheHive case creation (for high severity)
#
# Wazuh passes alert data as JSON via stdin or file argument.
# Configure in ossec.conf under <integration> block.
#
# Author: Alphonse Joseph & Filmon Mehari Gebrezghi
# University West, 2026
# ============================================================

import sys
import os
import json
import requests
import datetime
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# ── Configuration ─────────────────────────────────────────────────────────────
PROXY_URL   = "http://localhost:9090"
THEHIVE_URL = "http://localhost:9000"
THEHIVE_KEY = "YOUR_THEHIVE_API_KEY"  # [SENSITIVE — not shared. Generate in TheHive: Admin -> API Keys]
# ──────────────────────────────────────────────────────────────────────────────

LOG_FILE = "/var/ossec/logs/custom-thehive.log"


def log(msg):
    timestamp = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    with open(LOG_FILE, 'a') as f:
        f.write(f"[{timestamp}] {msg}\n")


def read_alert(alert_file):
    """Read alert JSON from file passed by Wazuh integratord."""
    try:
        with open(alert_file) as f:
            return json.load(f)
    except Exception as e:
        log(f"ERROR reading alert file: {e}")
        sys.exit(1)


def enrich_ip(ip):
    """
    WZ-PB2: Query AbuseIPDB via SOAR proxy.
    Returns dict with score, country, isp.
    """
    try:
        response = requests.get(
            f"{PROXY_URL}/check",
            params={"ip": ip},
            timeout=10
        )
        data = response.json().get("data", {})
        return {
            "score": data.get("abuseConfidenceScore", 0),
            "country": data.get("countryCode", "N/A"),
            "isp": data.get("isp", "N/A"),
            "reports": data.get("totalReports", 0)
        }
    except Exception as e:
        log(f"AbuseIPDB enrichment failed for {ip}: {e}")
        return {"score": 0, "country": "N/A", "isp": "N/A", "reports": 0}


def create_alert(alert, enrichment, ip):
    """
    WZ-PB3: Create structured alert in TheHive.
    """
    rule_id   = alert.get("rule", {}).get("id", "unknown")
    rule_desc = alert.get("rule", {}).get("description", "No description")
    agent     = alert.get("agent", {}).get("name", "unknown")
    level     = alert.get("rule", {}).get("level", 0)
    timestamp = alert.get("timestamp", "")

    description = (
        f"**Wazuh Alert**\n\n"
        f"- **Rule ID:** {rule_id}\n"
        f"- **Description:** {rule_desc}\n"
        f"- **Agent:** {agent}\n"
        f"- **Level:** {level}\n"
        f"- **Time:** {timestamp}\n\n"
        f"**Threat Intelligence (AbuseIPDB)**\n\n"
        f"- **Source IP:** {ip}\n"
        f"- **Abuse Score:** {enrichment['score']}%\n"
        f"- **Country:** {enrichment['country']}\n"
        f"- **ISP:** {enrichment['isp']}\n"
        f"- **Reports:** {enrichment['reports']}\n"
    )

    payload = {
        "title": f"Wazuh Alert: {rule_desc}",
        "description": description,
        "type": "wazuh",
        "source": "Wazuh-Integration",
        "sourceRef": f"wazuh-{rule_id}-{timestamp}",
        "severity": 2 if level < 10 else 3,
        "tags": ["wazuh", "automated", f"rule-{rule_id}"],
        "tlp": 2,
        "status": "New",
        "observables": [
            {
                "dataType": "ip",
                "data": ip,
                "message": f"Source IP — AbuseIPDB score: {enrichment['score']}%"
            }
        ]
    }

    try:
        response = requests.post(
            f"{THEHIVE_URL}/api/v1/alert",
            headers={
                "Authorization": f"Bearer {THEHIVE_KEY}",
                "Content-Type": "application/json"
            },
            json=payload,
            timeout=10
        )
        log(f"TheHive alert created: HTTP {response.status_code} for rule {rule_id}, IP {ip}")
        return response.status_code
    except Exception as e:
        log(f"TheHive alert creation failed: {e}")
        return 500


def create_case(alert, enrichment, ip):
    """
    WZ-PB4: Create full investigation case in TheHive.
    Triggered when AbuseIPDB score >= 75 or rule level >= 10.
    """
    rule_id   = alert.get("rule", {}).get("id", "unknown")
    rule_desc = alert.get("rule", {}).get("description", "No description")
    agent     = alert.get("agent", {}).get("name", "unknown")
    level     = alert.get("rule", {}).get("level", 0)

    description = (
        f"**High-severity incident detected by Wazuh**\n\n"
        f"- **Rule ID:** {rule_id}\n"
        f"- **Description:** {rule_desc}\n"
        f"- **Agent:** {agent}\n"
        f"- **Level:** {level}\n\n"
        f"**Attacker Profile (AbuseIPDB)**\n\n"
        f"- **Source IP:** {ip}\n"
        f"- **Abuse Score:** {enrichment['score']}%\n"
        f"- **Country:** {enrichment['country']}\n"
        f"- **ISP:** {enrichment['isp']}\n"
        f"- **Total Reports:** {enrichment['reports']}\n\n"
        f"**Actions Taken**\n\n"
        f"- FortiGate IP block triggered via active response\n"
        f"- AbuseIPDB enrichment completed\n"
        f"- TheHive alert created\n"
    )

    payload = {
        "title": f"Incident: {rule_desc} from {ip}",
        "description": description,
        "severity": 3,
        "tags": ["wazuh", "automated", "high-severity", f"rule-{rule_id}"],
        "tlp": 2,
        "flag": False,
        "tasks": [
            {
                "title": "Verify IP block on FortiGate",
                "description": f"Confirm that {ip} is blocked in FortiGate address objects"
            },
            {
                "title": "Investigate source IP",
                "description": f"Review AbuseIPDB reports for {ip} and assess threat level"
            },
            {
                "title": "Check for lateral movement",
                "description": "Review logs for other connections from this IP or subnet"
            }
        ]
    }

    try:
        response = requests.post(
            f"{THEHIVE_URL}/api/v1/case",
            headers={
                "Authorization": f"Bearer {THEHIVE_KEY}",
                "Content-Type": "application/json"
            },
            json=payload,
            timeout=10
        )
        log(f"TheHive case created: HTTP {response.status_code} for rule {rule_id}, IP {ip}")
        return response.status_code
    except Exception as e:
        log(f"TheHive case creation failed: {e}")
        return 500


def main():
    # Wazuh passes alert file path as first argument
    if len(sys.argv) < 2:
        log("ERROR: No alert file argument provided")
        sys.exit(1)

    alert_file = sys.argv[1]
    alert = read_alert(alert_file)

    # Extract source IP
    ip = (
        alert.get("data", {}).get("srcip") or
        alert.get("data", {}).get("src_ip") or
        alert.get("agent", {}).get("ip") or
        ""
    )

    rule_level = alert.get("rule", {}).get("level", 0)
    rule_id    = alert.get("rule", {}).get("id", "unknown")

    log(f"Processing alert: rule {rule_id}, level {rule_level}, IP {ip}")

    # WZ-PB2: Enrich IP
    enrichment = {"score": 0, "country": "N/A", "isp": "N/A", "reports": 0}
    if ip:
        enrichment = enrich_ip(ip)
        log(f"Enrichment for {ip}: score={enrichment['score']}%, country={enrichment['country']}")

    # WZ-PB3: Always create TheHive alert
    create_alert(alert, enrichment, ip)

    # WZ-PB4: Create case if high severity
    if enrichment["score"] >= 75 or rule_level >= 10:
        log(f"High severity detected — creating TheHive case for {ip}")
        create_case(alert, enrichment, ip)

    log("Integration complete")
    sys.exit(0)


if __name__ == "__main__":
    main()
